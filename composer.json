{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "repositories": [
        {
            "type": "package",
            "package": {
                "name": "milon/barcode",
                "version": "11.0.1",
                "source": {
                    "url": "https://github.com/milon/barcode.git",
                    "type": "git",
                    "reference": "v11.0.1"
                },
                "require": {
                    "php": ">=8.0",
                    "illuminate/support": "^9.0|^10.0|^11.0|^12.0"
                },
                "autoload": {
                    "psr-0": {
                        "Milon\\Barcode": "src/"
                    }
                },
                "extra": {
                    "laravel": {
                        "providers": [
                            "Milon\\Barcode\\BarcodeServiceProvider"
                        ],
                        "aliases": {
                            "DNS1D": "Milon\\Barcode\\Facades\\DNS1DFacade",
                            "DNS2D": "Milon\\Barcode\\Facades\\DNS2DFacade"
                        }
                    }
                }
            }
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.9",
        "hisorange/browser-detect": "^4.5",
        "jenssegers/agent": "^2.6",
        "jorenvanhocht/laravel-share": "^4.2",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.16",
        "laravel/tinker": "^2.9",
        "maatwebsite/excel": "^3.1",
        "mews/captcha": "^3.3",
        "milon/barcode": "^11.0",
        "owen-it/laravel-auditing": "^14.0",
        "pusher/pusher-php-server": "^7.2",
        "spatie/laravel-permission": "^6.23"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.14",
        "fakerphp/faker": "^1.9.1",
        "laravel/breeze": "^2.3",
        "laravel/sail": "^1.36",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/chamnanHelpers.php",
            "app/Libraries/LicenseManager.php",
            "app/Libraries/LibrariesNan.php",
            "app/Helpers/license_helper.php",
            "app/core/admin_core.php",
            "app/core/shop_core.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
